rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * Checks if the request is originating from a securely authenticated session.
     */
    function isAuthenticated() {
      return request.auth != null;
    }
    
    /**
     * Checks if the active authenticated UID matches the target path owner.
     */
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // 1. Core User Isolation Boundaries
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Timelines and active crunch episodes
      match /episodes/{episodeId} {
        allow read, write: if isOwner(userId);
      }
      
      // File upload metadata records
      match /uploads/{fileId} {
        allow read, write: if isOwner(userId);
      }
      
      // Focus efficiency and task metrics
      match /focus_metrics/{metricId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // 2. Public Metadata for connection verification
    match /system_metadata/connection_probe {
      allow read: if true; // Connection checking during app bootstrap
      allow write: if false; // Immutable client-side
    }
    
    // Default Deny-All fallback rule
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
