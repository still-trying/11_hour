# ==============================================
# 11_HOUR — Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# ==============================================

# --- Supabase (Required for Auth & Data) ---
# Get these from your Supabase project dashboard:
#   Project Settings > API > Project URL & anon/public key
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# --- Gemini AI (Required for AI features) ---
# Get an API key from: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY="your-gemini-api-key"

# --- App Environment ---
# Options: development | production | test
VITE_APP_ENV="development"

# --- Feature Flags ---
# Set to "true" or "false" to enable/disable features
VITE_ENABLE_ANALYTICS="false"
VITE_ENABLE_DIAGNOSTICS="true"
VITE_ENABLE_SELF_HEALING="true"
VITE_ENABLE_HOTKEYS="true"

# --- Performance ---
# API timeout in milliseconds (default: 10000)
VITE_API_TIMEOUT_MS="10000"

# --- Debug ---
# Set to "true" to enable verbose debug logging
VITE_DEBUG_MODE="true"
